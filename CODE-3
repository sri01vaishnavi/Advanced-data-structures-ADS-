#include <stdio.h>
#include <stdlib.h>
#define SIZE 10
int linear[SIZE];
struct node
{
int data;
struct node *next;
};
struct node* chain[SIZE];
int hash2(int key)
{
return 7 - (key % 7);
}
void insertLinear(int key)
{
int index = key % SIZE;
int i = 0;
while(i < SIZE && linear[index] != -1)
{
index = (index + 1) % SIZE;
i++;
}
if(i == SIZE)
printf("Linear table full\n");
else
linear[index] = key;
}
void displayLinear()
{
printf("\nLinear Probing:\n");
for(int i=0;i<SIZE;i++)
{
if(linear[i] != -1)
printf("%d -> %d\n", i, linear[i]);
else
printf("%d -> Empty\n", i);
}
}
int main()
{
int n,key;
for(int i=0;i<SIZE;i++)
{
linear[i] = -1;
}
printf("Enter number of elements: ");
scanf("%d",&n);
for(int i=0;i<n;i++)
{
printf("Enter key: ");
scanf("%d",&key);
insertLinear(key);

}
displayLinear();
return 0;
}
